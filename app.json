{
  "expo": {
    "name": "anotherday",
    "slug": "anotherday",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/anotherday-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/anotherday-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anotherday.app",
      "infoPlist": {
        "NSCameraUsageDescription": "목표 인증을 위해 카메라 접근 권한이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "인증 사진을 저장하기 위해 사진 라이브러리 접근 권한이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/anotherday-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./assets/anotherday-icon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "목표 인증을 위해 카메라 접근 권한이 필요합니다.",
          "photosPermission": "인증 사진을 저장하기 위해 사진 라이브러리 접근 권한이 필요합니다."
        }
      ]
    ]
  }
}
