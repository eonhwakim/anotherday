{
  "expo": {
    "name": "anotherday",
    "slug": "anotherday",
    "version": "1.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/brand-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brand-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "url": "https://u.expo.dev/c16b46a9-0655-4c45-b569-c8d329d506a1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anotherday.app",
      "buildNumber": "7",
      "infoPlist": {
        "NSCameraUsageDescription": "목표 인증을 위해 카메라 접근 권한이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "인증 사진을 저장하기 위해 사진 라이브러리 접근 권한이 필요합니다.",
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/anotherday-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/anotherday-icon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "목표 인증을 위해 카메라 접근 권한이 필요합니다.",
          "photosPermission": "인증 사진을 저장하기 위해 사진 라이브러리 접근 권한이 필요합니다."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c16b46a9-0655-4c45-b569-c8d329d506a1"
      }
    },
    "owner": "eona"
  }
}
